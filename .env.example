# mnms — example environment file
#
# Copy this to `.env` at the repo root and fill in real values:
#
#     cp .env.example .env
#
# The real `.env` is git-ignored (see .gitignore); this template is tracked.
# Every branch loads this single root file via python-dotenv
# (`load_dotenv(REPO_ROOT / ".env")`). There is no per-branch env file.
#
# "Required" below means the code reads it with `os.environ[...]` and will
# crash immediately if it's missing. "Optional" means the code runs without it.


# ─────────────────────────────────────────────────────────────────────────────
# OSU LiteLLM proxy — the single entry point for ALL LLM calls
# ─────────────────────────────────────────────────────────────────────────────
# Used as an OpenAI-compatible endpoint: the branches point the OpenAI SDK's
# base_url at "$LITELLM_URL/v1" and send LITELLM_KEY as the API key.
#
# REQUIRED for:  corpus_coding, structure_analysis, bt_scoring
#   (each does os.environ["LITELLM_URL"] / os.environ["LITELLM_KEY"] — no default)
# ALSO USED BY:  the coding-agent flakes under envs/ (claude-code, codex-cli,
#                pi, opencode) — `nix develop` sources this .env and wires the
#                agent to the proxy.
# NOT NEEDED for: transcription (local Granite ASR only, no proxy calls)
#
LITELLM_URL=https://litellm.cloud.osu.edu
LITELLM_KEY=sk-your-litellm-key-here


# ─────────────────────────────────────────────────────────────────────────────
# Hugging Face token
# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED for:  transcription
#   (transcription/main.py does os.environ["HF_TOKEN"] with no default and
#    passes it to datasets.load_dataset(...) to stream the gated Common Voice
#    ESB test split — the run crashes with a KeyError if it's absent.)
# NOT NEEDED for: corpus_coding, structure_analysis, data_acquisition.
#   Note: bt_scoring also runs Granite-Speech ASR, but downloads a *public*
#   model via transformers, so it does not require a token. Set one anyway if
#   you hit HF download rate limits.
#
# Create one at https://huggingface.co/settings/tokens (read scope is enough).
#
HF_TOKEN=hf_your_hugging_face_token_here


# ─────────────────────────────────────────────────────────────────────────────
# Contact email for the data-acquisition User-Agent
# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL — and currently INACTIVE in code.
#   data_acquisition/common.py documents a polite, identifying User-Agent that
#   includes a contact address from CONTACT_EMAIL, but that line is presently
#   commented out; the fetchers send a static User-Agent and never read this
#   variable. Set it so it's ready if/when that code path is re-enabled — good
#   etiquette when hitting arXiv / NCBI / NSF / Internet Archive at volume.
#
CONTACT_EMAIL=you@osu.edu
